<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="crossbrowser">

	<test thread-count="5" name="FirefoxTest">
	<parameter name="browsers" value="firefox"></parameter>
		<classes>

			<class name="testscript.ManageNewsTest">
			<methods>
			<include name="verifyWhetheUserCanSearchNews"></include>
			</methods>
		
			</class>
		</classes>
	</test> 
	<test thread-count="5" name="ChromeTest">
	<parameter name="browsers" value="chromer"></parameter>
		<classes>

			<class name="testscript.ManageNewsTest">
			<methods>
			<include name="verifyWhetheUserCanSearchNews"></include>
			</methods>
		
			</class>
		</classes>
	</test> 
	<test thread-count="5" name="EdgeTest">
	<parameter name="browsers" value="edge"></parameter>
		<classes>

			<class name="testscript.ManageNewsTest">
			<methods>
			<include name="verifyWhetheUserCanSearchNews"></include>
			</methods>
		
			</class>
		</classes>
	</test> 
</suite> 
